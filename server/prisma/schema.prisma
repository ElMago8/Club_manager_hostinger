generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SalaCultivo {
  id                       Int      @id @default(autoincrement())
  codigoSala               String   @unique @map("codigo_sala")
  nombre                   String
  tipo                     String
  estado                   String   @default("activa")
  potenciaWatts            Int      @default(0) @map("potencia_watts")
  tipoRiego                String   @default("manual") @map("tipo_riego")
  tieneAireAcondicionado   Boolean  @default(false) @map("tiene_aire_acondicionado")
  tieneDeshumidificador    Boolean  @default(false) @map("tiene_deshumidificador")
  sensores                 String?
  descripcion              String?
  creadoEn                 DateTime @default(now()) @map("creado_en")
  actualizadoEn            DateTime @updatedAt @map("actualizado_en")

  camillas              Camilla[]
  madres                Madre[]
  lotesCultivo          LoteCultivo[]
  registrosAmbientales  RegistroAmbiental[]
  tareasCultivo         TareaCultivo[]
  medicionesCultivo     MedicionCultivo[]

  @@map("salas_cultivo")
}

model Camilla {
  id                     Int      @id @default(autoincrement())
  codigoCamilla          String   @unique @map("codigo_camilla")
  salaCultivoId          Int      @map("sala_cultivo_id")
  nombre                 String
  estado                 String   @default("activa")
  capacidadMaximaPlantas Int      @map("capacidad_maxima_plantas")
  descripcion            String?
  creadoEn               DateTime @default(now()) @map("creado_en")
  actualizadoEn          DateTime @updatedAt @map("actualizado_en")

  salaCultivo          SalaCultivo          @relation(fields: [salaCultivoId], references: [id], onDelete: Restrict)
  madres               Madre[]
  plantas              Planta[]
  tareasCultivo        TareaCultivo[]
  registrosAmbientales RegistroAmbiental[]
  medicionesCultivo    MedicionCultivo[]

  @@index([salaCultivoId])
  @@map("camillas")
}

model Genetica {
  id                  Int      @id @default(autoincrement())
  codigoGenetica      String   @unique @map("codigo_genetica")
  nombre              String
  breeder             String?
  tipo                String
  thcEstimado         Float?   @map("thc_estimado")
  cbdEstimado         Float?   @map("cbd_estimado")
  sativaPorcentaje    Float?   @map("sativa_porcentaje")
  indicaPorcentaje    Float?   @map("indica_porcentaje")
  sabor               String?
  efecto              String?
  aroma               String?
  tiempoFloracionDias Int?     @map("tiempo_floracion_dias")
  estado              String   @default("activa")
  descripcion         String?
  observaciones       String?
  creadoEn            DateTime @default(now()) @map("creado_en")
  actualizadoEn       DateTime @updatedAt @map("actualizado_en")

  madres       Madre[]
  lotesCultivo LoteCultivo[]
  plantas      Planta[]

  @@map("geneticas")
}

model Madre {
  id                            Int       @id @default(autoincrement())
  codigoMadre                   String    @unique @map("codigo_madre")
  nombreMadre                   String?   @map("nombre_madre")
  geneticaId                    Int       @map("genetica_id")
  salaCultivoId                 Int       @map("sala_cultivo_id")
  camillaId                     Int       @map("camilla_id")
  estado                        String    @default("activa")
  estadoSanitario               String    @default("bueno") @map("estado_sanitario")
  fechaInicio                   DateTime  @map("fecha_inicio")
  fechaUltimoCorte              DateTime? @map("fecha_ultimo_corte")
  cantidadEsquejesDisponibles   Int       @default(0) @map("cantidad_esquejes_disponibles")
  origen                        String?
  observaciones                 String?
  creadoEn                      DateTime  @default(now()) @map("creado_en")
  actualizadoEn                 DateTime  @updatedAt @map("actualizado_en")

  genetica          Genetica          @relation(fields: [geneticaId], references: [id], onDelete: Restrict)
  salaCultivo       SalaCultivo       @relation(fields: [salaCultivoId], references: [id], onDelete: Restrict)
  camilla           Camilla           @relation(fields: [camillaId], references: [id], onDelete: Restrict)
  plantas           Planta[]
  medicionesCultivo MedicionCultivo[]

  @@index([geneticaId])
  @@index([salaCultivoId])
  @@index([camillaId])
  @@map("madres")
}

model LoteCultivo {
  id                    Int       @id @default(autoincrement())
  codigoLote            String    @unique @map("codigo_lote")
  geneticaId            Int       @map("genetica_id")
  salaCultivoId         Int       @map("sala_cultivo_id")
  fechaInicio           DateTime  @map("fecha_inicio")
  fechaInicioFloracion  DateTime? @map("fecha_inicio_floracion")
  fechaEstimadaCosecha  DateTime? @map("fecha_estimada_cosecha")
  fechaCosechaReal      DateTime? @map("fecha_cosecha_real")
  estado                String    @default("activo")
  observaciones         String?
  creadoEn              DateTime  @default(now()) @map("creado_en")
  actualizadoEn         DateTime  @updatedAt @map("actualizado_en")

  genetica              Genetica              @relation(fields: [geneticaId], references: [id], onDelete: Restrict)
  salaCultivo           SalaCultivo           @relation(fields: [salaCultivoId], references: [id], onDelete: Restrict)
  plantas               Planta[]
  registrosAmbientales  RegistroAmbiental[]
  riegos                Riego[]
  tareasCultivo         TareaCultivo[]
  cosechas              Cosecha[]

  @@index([geneticaId])
  @@index([salaCultivoId])
  @@map("lotes_cultivo")
}

model Planta {
  id               Int       @id @default(autoincrement())
  codigoPlanta     String    @unique @map("codigo_planta")
  nombrePlanta     String    @map("nombre_planta")
  loteCultivoId    Int?      @map("lote_cultivo_id")
  geneticaId       Int       @map("genetica_id")
  madreId          Int?      @map("madre_id")
  camillaId        Int       @map("camilla_id")
  posicionCamilla  Int       @map("posicion_camilla")
  origen           String
  etapa            String
  estado           String    @default("activa")
  fechaInicio      DateTime  @map("fecha_inicio")
  fechaInicioEtapa DateTime? @map("fecha_inicio_etapa")
  macetaCodigo     String?   @map("maceta_codigo")
  macetaLitros     Float?    @map("maceta_litros")
  tipoMaceta       String?   @map("tipo_maceta")
  sustrato         String?
  estadoSanitario  String?   @default("bueno") @map("estado_sanitario")
  observaciones    String?
  creadoEn         DateTime  @default(now()) @map("creado_en")
  actualizadoEn    DateTime  @updatedAt @map("actualizado_en")

  loteCultivo       LoteCultivo?       @relation(fields: [loteCultivoId], references: [id], onDelete: SetNull)
  genetica          Genetica           @relation(fields: [geneticaId], references: [id], onDelete: Restrict)
  madre             Madre?             @relation(fields: [madreId], references: [id], onDelete: SetNull)
  camilla           Camilla            @relation(fields: [camillaId], references: [id], onDelete: Restrict)
  riegos            Riego[]
  medicionesCultivo MedicionCultivo[]
  tareasCultivo     TareaCultivo[]

  @@unique([camillaId, posicionCamilla])
  @@index([loteCultivoId])
  @@index([geneticaId])
  @@index([madreId])
  @@index([camillaId])
  @@map("plantas")
}

model RegistroAmbiental {
  id             Int      @id @default(autoincrement())
  salaCultivoId  Int      @map("sala_cultivo_id")
  loteCultivoId  Int?     @map("lote_cultivo_id")
  camillaId      Int?     @map("camilla_id")
  temperatura    Float
  humedad        Float
  vpd            Float?
  co2            Int?
  observaciones  String?
  registradoEn   DateTime @default(now()) @map("registrado_en")
  creadoEn       DateTime @default(now()) @map("creado_en")

  salaCultivo SalaCultivo  @relation(fields: [salaCultivoId], references: [id], onDelete: Restrict)
  loteCultivo LoteCultivo? @relation(fields: [loteCultivoId], references: [id], onDelete: SetNull)
  camilla     Camilla?     @relation(fields: [camillaId], references: [id], onDelete: SetNull)

  @@index([salaCultivoId])
  @@index([loteCultivoId])
  @@index([camillaId])
  @@index([registradoEn])
  @@map("registros_ambientales")
}

model Riego {
  id             Int      @id @default(autoincrement())
  plantaId       Int?     @map("planta_id")
  loteCultivoId  Int?     @map("lote_cultivo_id")
  tipoRiego      String   @map("tipo_riego")
  volumenLitros  Float    @map("volumen_litros")
  ph             Float?
  ec             Float?
  observaciones  String?
  fechaRiego     DateTime @default(now()) @map("fecha_riego")
  creadoEn       DateTime @default(now()) @map("creado_en")

  planta      Planta?      @relation(fields: [plantaId], references: [id], onDelete: SetNull)
  loteCultivo LoteCultivo? @relation(fields: [loteCultivoId], references: [id], onDelete: SetNull)

  @@index([plantaId])
  @@index([loteCultivoId])
  @@index([fechaRiego])
  @@map("riegos")
}

model MedicionCultivo {
  id             Int      @id @default(autoincrement())
  fecha          DateTime @map("fecha")
  hora           String   @map("hora")
  tipo           String
  salaCultivoId  Int      @map("sala_cultivo_id")
  camillaId      Int?     @map("camilla_id")
  plantaId       Int?     @map("planta_id")
  madreId        Int?     @map("madre_id")
  phLiquido      Float?   @map("ph_liquido")
  ppmLiquido     Float?   @map("ppm_liquido")
  phSustrato     Float?   @map("ph_sustrato")
  ppmSustrato    Float?   @map("ppm_sustrato")
  phDrenaje      Float?   @map("ph_drenaje")
  ppmDrenaje     Float?   @map("ppm_drenaje")
  estado         String   @default("normal")
  responsable    String?
  observaciones  String?
  creadoEn       DateTime @default(now()) @map("creado_en")
  actualizadoEn  DateTime @updatedAt @map("actualizado_en")

  salaCultivo SalaCultivo @relation(fields: [salaCultivoId], references: [id], onDelete: Restrict)
  camilla     Camilla?    @relation(fields: [camillaId], references: [id], onDelete: SetNull)
  planta      Planta?     @relation(fields: [plantaId], references: [id], onDelete: SetNull)
  madre       Madre?      @relation(fields: [madreId], references: [id], onDelete: SetNull)

  @@index([salaCultivoId])
  @@index([camillaId])
  @@index([plantaId])
  @@index([madreId])
  @@index([fecha])
  @@map("mediciones_cultivo")
}

model TareaCultivo {
  id              Int       @id @default(autoincrement())
  titulo          String
  descripcion     String?
  tipo            String
  prioridad       String   @default("media")
  estado          String   @default("pendiente")
  salaCultivoId   Int?     @map("sala_cultivo_id")
  camillaId       Int?     @map("camilla_id")
  loteCultivoId   Int?     @map("lote_cultivo_id")
  plantaId        Int?     @map("planta_id")
  fechaProgramada DateTime @map("fecha_programada")
  fechaCompletada DateTime? @map("fecha_completada")
  observaciones   String?
  creadoEn        DateTime @default(now()) @map("creado_en")
  actualizadoEn   DateTime @updatedAt @map("actualizado_en")

  salaCultivo SalaCultivo? @relation(fields: [salaCultivoId], references: [id], onDelete: SetNull)
  camilla     Camilla?     @relation(fields: [camillaId], references: [id], onDelete: SetNull)
  loteCultivo LoteCultivo? @relation(fields: [loteCultivoId], references: [id], onDelete: SetNull)
  planta      Planta?      @relation(fields: [plantaId], references: [id], onDelete: SetNull)

  @@index([estado])
  @@index([prioridad])
  @@index([tipo])
  @@index([salaCultivoId])
  @@index([camillaId])
  @@index([loteCultivoId])
  @@index([plantaId])
  @@index([fechaProgramada])
  @@map("tareas_cultivo")
}

model Cosecha {
  id                Int       @id @default(autoincrement())
  codigoCosecha     String    @unique @map("codigo_cosecha")
  loteCultivoId     Int       @map("lote_cultivo_id")
  fechaCosecha      DateTime  @map("fecha_cosecha")
  pesoHumedoGramos  Float?    @map("peso_humedo_gramos")
  pesoSecoGramos    Float?    @map("peso_seco_gramos")
  pesoMermaGramos   Float?    @map("peso_merma_gramos")
  estado            String    @default("registrada")
  observaciones     String?
  creadoEn          DateTime  @default(now()) @map("creado_en")
  actualizadoEn     DateTime  @updatedAt @map("actualizado_en")

  loteCultivo LoteCultivo @relation(fields: [loteCultivoId], references: [id], onDelete: Restrict)

  @@index([loteCultivoId])
  @@map("cosechas")
}

// ─── Fase 2.1: Usuarios, Roles y Permisos ────────────────────────────────────

model Usuario {
  id             Int       @id @default(autoincrement())
  codigoUsuario  String    @unique @map("codigo_usuario")
  username       String    @unique
  nombre         String
  apellido       String?
  email          String?
  passwordHash   String    @map("password_hash")
  estado         String    @default("activo")
  ultimoLoginEn  DateTime? @map("ultimo_login_en")
  creadoEn       DateTime  @default(now()) @map("creado_en")
  actualizadoEn  DateTime  @updatedAt @map("actualizado_en")

  roles UsuarioRol[]

  @@map("usuarios")
}

model Rol {
  id            Int       @id @default(autoincrement())
  slug          String    @unique
  nombre        String    @unique
  descripcion   String?
  estado        String    @default("activo")
  creadoEn      DateTime  @default(now()) @map("creado_en")
  actualizadoEn DateTime  @updatedAt @map("actualizado_en")

  usuarios UsuarioRol[]
  permisos RolPermiso[]

  @@map("roles")
}

model Permiso {
  id           Int      @id @default(autoincrement())
  clavePermiso String   @unique @map("clave_permiso")
  modulo       String
  accion       String
  descripcion  String?
  creadoEn     DateTime @default(now()) @map("creado_en")

  roles RolPermiso[]

  @@map("permisos")
}

model UsuarioRol {
  id        Int      @id @default(autoincrement())
  usuarioId Int      @map("usuario_id")
  rolId     Int      @map("rol_id")
  creadoEn  DateTime @default(now()) @map("creado_en")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  rol     Rol     @relation(fields: [rolId], references: [id], onDelete: Restrict)

  @@unique([usuarioId, rolId])
  @@index([usuarioId])
  @@index([rolId])
  @@map("usuario_roles")
}

model RolPermiso {
  id        Int      @id @default(autoincrement())
  rolId     Int      @map("rol_id")
  permisoId Int      @map("permiso_id")
  creadoEn  DateTime @default(now()) @map("creado_en")

  rol     Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)
  permiso Permiso @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  @@unique([rolId, permisoId])
  @@index([rolId])
  @@index([permisoId])
  @@map("rol_permisos")
}
